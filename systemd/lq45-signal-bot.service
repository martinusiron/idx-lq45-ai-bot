[Unit]
Description=LQ45 AI Signal Bot
After=network.target

[Service]
Type=simple
WorkingDirectory=/home/martinus/idx-lq45-ai-bot
Environment=PATH=/home/martinus/idx-lq45-ai-bot/venv/bin
ExecStart=/home/martinus/idx-lq45-ai-bot/venv/bin/python3 /home/martinus/idx-lq45-ai-bot/main.py
Restart=always
RestartSec=10
User=root

[Install]
WantedBy=multi-user.target
